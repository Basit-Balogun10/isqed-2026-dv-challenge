      reset_val: "0x00000000"
      access: "W1S"
      fields: [
        {
          name: "wipe"
          bits: "0"
          desc: "Write 1 to wipe secret key from key registers"
          access: "W1S"
          reset_val: "0x0"
        }
      ]
    }
