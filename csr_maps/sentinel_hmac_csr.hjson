{
  name: "sentinel_hmac"
  base_addr: "0x0"
  registers: [
    {
      name: "CFG"
      desc: "HMAC configuration register"
      offset: "0x00"
      reset_val: "0x00000000"
      access: "RW"
      fields: [
        {
          name: "hmac_en"
          bits: "0"
          desc: "Enable HMAC mode (when 0, operates as SHA-256 only)"
          access: "RW"
          reset_val: "0x0"
        }
        {
          name: "sha_en"
          bits: "1"
          desc: "Enable SHA-256 engine"
          access: "RW"
          reset_val: "0x0"
        }
        {
          name: "endian_swap"
          bits: "2"
          desc: "Swap endianness of input message data"
          access: "RW"
          reset_val: "0x0"
        }
        {
          name: "digest_swap"
          bits: "3"
          desc: "Swap endianness of output digest"
          access: "RW"
          reset_val: "0x0"
        }
      ]
    }
    {
      name: "CMD"
      desc: "HMAC command register (write 1 to set)"
      offset: "0x04"
      reset_val: "0x00000000"
      access: "W1S"
      fields: [
        {
          name: "hash_start"
          bits: "0"
          desc: "Write 1 to start hashing operation"
          access: "W1S"
          reset_val: "0x0"
        }
        {
          name: "hash_process"
          bits: "1"
          desc: "Write 1 to process remaining data in FIFO"
          access: "W1S"
          reset_val: "0x0"
        }
        {
          name: "hash_stop"
          bits: "2"
          desc: "Write 1 to stop hashing and generate digest"
          access: "W1S"
          reset_val: "0x0"
        }
      ]
    }
    {
      name: "STATUS"
      desc: "HMAC status register"
      offset: "0x08"
      reset_val: "0x00000102"
      access: "RO"
      fields: [
        {
          name: "fifo_full"
          bits: "0"
          desc: "Message FIFO is full"
          access: "RO"
          reset_val: "0x0"
        }
        {
          name: "fifo_empty"
          bits: "1"
          desc: "Message FIFO is empty"
          access: "RO"
          reset_val: "0x1"
        }
        {
          name: "fifo_depth"
          bits: "7:2"
          desc: "Number of entries in the message FIFO"
          access: "RO"
          reset_val: "0x0"
        }
        {
          name: "sha_idle"
          bits: "8"
          desc: "SHA-256 engine is idle"
          access: "RO"
          reset_val: "0x1"
        }
      ]
    }
    {
      name: "WIPE_SECRET"
      desc: "Wipe secret key register (write 1 to set)"
